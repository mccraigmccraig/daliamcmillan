---
const year = new Date().getFullYear();

const links = [
  { href: "/about/", label: "About" },
  { href: "/how-it-works/", label: "How it works" },
  { href: "/what-i-can-help-with/", label: "What I help with" },
  { href: "/contact/", label: "Contact" },
];
---

<footer class="mt-24 border-t border-cream-200/70 bg-cream-50">
  <div class="container py-14">
    <div class="grid gap-10 md:grid-cols-3 md:gap-8">
      <div>
        <a href="/" class="inline-flex items-center gap-2.5" aria-label="Dalia McMillan — home">
          <span class="grid h-9 w-9 place-items-center rounded-full bg-primary text-primary-foreground shadow-soft">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 2c1.5 3 4.5 5 7 5-1.5 3-1.5 6 0 9-2.5 0-5.5 2-7 5-1.5-3-4.5-5-7-5 1.5-3 1.5-6 0-9 2.5 0 5.5-2 7-5Z"/>
            </svg>
          </span>
          <span class="font-display text-2xl leading-none tracking-tight">Dalia McMillan</span>
        </a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-muted-foreground">
          Solution Focused Hypnotherapy with Dalia McMillan. In person in Brighton, or online wherever you are.
        </p>
      </div>

      <nav aria-label="Footer" class="md:justify-self-center">
        <h2 class="font-display text-sm uppercase tracking-[0.18em] text-muted-foreground">Explore</h2>
        <ul class="mt-4 space-y-2.5 text-sm">
          {links.map((link) => (
            <li>
              <a href={link.href} class="text-foreground hover:text-primary transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="md:justify-self-end md:text-right">
        <h2 class="font-display text-sm uppercase tracking-[0.18em] text-muted-foreground">Get in touch</h2>
        <ul class="mt-4 space-y-2.5 text-sm">
          <li>
            <a href="mailto:dalia@daliamcmillan.uk" class="text-foreground hover:text-primary transition-colors">
              dalia@daliamcmillan.uk
            </a>
          </li>
          <li class="text-muted-foreground">Brighton &amp; Online</li>
          <li>
            <a
              href="https://calendly.com/daliamcdalia"
              target="_blank"
              rel="noopener"
              class="text-terracotta-500 hover:text-terracotta-400 transition-colors"
            >
              Book on Calendly →
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col-reverse gap-3 border-t border-cream-200 pt-6 text-xs text-muted-foreground md:flex-row md:items-center md:justify-between">
      <p>© {year} Dalia McMillan · Brighton &amp; Online</p>
      <p class="tracking-wide">Trained with CPHT · Member of AfSFH · Fully insured</p>
    </div>
  </div>
</footer>
