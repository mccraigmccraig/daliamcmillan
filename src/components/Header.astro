---
import BookingButton from "@/components/BookingButton.astro";

const navLinks = [
  { href: "/about/", label: "About" },
  { href: "/how-it-works/", label: "How it works" },
  { href: "/what-i-can-help-with/", label: "What I help with" },
  { href: "/contact/", label: "Contact" },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header class="sticky top-0 z-40 w-full border-b border-cream-200/70 bg-background/85 backdrop-blur-md">
  <div class="container flex h-20 items-center justify-between gap-6">
    <a
      href="/"
      class="group flex items-center gap-2.5"
      aria-label="Dalia McMillan — home"
    >
      <span class="grid h-9 w-9 place-items-center rounded-full bg-primary text-primary-foreground shadow-soft transition-transform duration-500 group-hover:rotate-[8deg]">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2c1.5 3 4.5 5 7 5-1.5 3-1.5 6 0 9-2.5 0-5.5 2-7 5-1.5-3-4.5-5-7-5 1.5-3 1.5-6 0-9 2.5 0 5.5-2 7-5Z"/>
        </svg>
      </span>
      <span class="font-display text-2xl leading-none tracking-tight text-foreground">Dalia McMillan</span>
    </a>

    <nav aria-label="Primary" class="hidden lg:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "text-[15px] transition-colors",
            isActive(link.href)
              ? "text-primary font-medium"
              : "text-muted-foreground hover:text-foreground",
          ]}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="hidden lg:block">
      <BookingButton label="Book Now" size="md" />
    </div>

    <button
      id="nav-toggle"
      type="button"
      class="lg:hidden inline-flex h-11 w-11 items-center justify-center rounded-full border border-cream-300 text-primary hover:bg-cream-100"
      aria-controls="mobile-nav"
      aria-expanded="false"
      aria-label="Open menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" data-open>
        <line x1="4" y1="7" x2="20" y2="7"/>
        <line x1="4" y1="12" x2="20" y2="12"/>
        <line x1="4" y1="17" x2="20" y2="17"/>
      </svg>
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" data-close class="hidden">
        <line x1="6" y1="6" x2="18" y2="18"/>
        <line x1="6" y1="18" x2="18" y2="6"/>
      </svg>
    </button>
  </div>

  <nav
    id="mobile-nav"
    aria-label="Primary mobile"
    class="hidden lg:hidden border-t border-cream-200/70 bg-background"
  >
    <ul class="container flex flex-col gap-1 py-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "block rounded-md px-3 py-3 text-base transition-colors",
              isActive(link.href)
                ? "text-primary font-medium bg-cream-100"
                : "text-foreground hover:bg-cream-100",
            ]}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <BookingButton label="Book Now" class="w-full" />
      </li>
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const mobileNav = document.getElementById("mobile-nav");
  const openIcon = toggle?.querySelector("[data-open]");
  const closeIcon = toggle?.querySelector("[data-close]");

  if (toggle && mobileNav && openIcon && closeIcon) {
    toggle.addEventListener("click", () => {
      const isOpen = mobileNav.classList.toggle("hidden") === false;
      toggle.setAttribute("aria-expanded", String(isOpen));
      toggle.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu");
      openIcon.classList.toggle("hidden", isOpen);
      closeIcon.classList.toggle("hidden", !isOpen);
    });
  }
</script>
