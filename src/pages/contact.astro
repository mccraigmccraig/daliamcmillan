---
import Layout from "@/layouts/Layout.astro";
import BookingButton from "@/components/BookingButton.astro";

const description =
  "Get in touch with Dalia McMillan — Solution Focused Hypnotherapy in Brighton and online. Free initial consultation. Email dalia@daliamcmillan.uk.";
---

<Layout title="Contact" description={description}>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-gradient-warm opacity-70" aria-hidden="true"></div>
    <div class="container py-20 lg:py-28">
      <div class="max-w-3xl">
        <p class="text-xs uppercase tracking-[0.2em] text-terracotta-500">Contact</p>
        <h1 class="mt-4 font-display text-5xl leading-[1.05] tracking-tight sm:text-6xl">
          Let's <em class="italic text-primary">talk.</em>
        </h1>
        <p class="mt-8 text-lg leading-relaxed text-foreground/85 sm:text-xl">
          The easiest first step is a free initial consultation — no obligation, just a conversation about what you'd like to be different, and whether we'd be a good fit to work together.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-24 sm:pb-32">
    <div class="container grid gap-10 lg:grid-cols-[1fr_1.15fr] lg:gap-14">
      <!-- Details + primary CTA -->
      <aside class="flex flex-col gap-6">
        <div class="rounded-[1.75rem] border border-cream-200 bg-cream-50 p-8 shadow-soft">
          <p class="text-xs uppercase tracking-[0.2em] text-terracotta-500">Book directly</p>
          <h2 class="mt-3 font-display text-2xl leading-snug text-foreground">
            Book your free consultation on Calendly
          </h2>
          <p class="mt-3 text-[15px] leading-relaxed text-muted-foreground">
            Choose a time that works for you — everything's in one place.
          </p>
          <div class="mt-6">
            <BookingButton size="lg" label="Open Calendly" />
          </div>
        </div>

        <div class="rounded-[1.75rem] border border-cream-200 bg-background p-8 shadow-soft">
          <p class="text-xs uppercase tracking-[0.2em] text-terracotta-500">Or reach out</p>
          <dl class="mt-4 space-y-5 text-[15px]">
            <div>
              <dt class="font-medium text-foreground">Email</dt>
              <dd class="mt-1">
                <a
                  href="mailto:dalia@daliamcmillan.uk"
                  class="text-primary underline underline-offset-4 hover:text-terracotta-500 transition-colors"
                >
                  dalia@daliamcmillan.uk
                </a>
              </dd>
            </div>
            <div>
              <dt class="font-medium text-foreground">Location</dt>
              <dd class="mt-1 text-muted-foreground">Brighton &amp; online sessions available</dd>
            </div>
            <div>
              <dt class="font-medium text-foreground">Free initial consultation</dt>
              <dd class="mt-1 text-muted-foreground">
                Includes a simple explanation of the neuroscience, so you feel confident from the very first step.
              </dd>
            </div>
          </dl>
        </div>
      </aside>

      <!-- Contact form (mailto fallback for v1) -->
      <form
        action="mailto:dalia@daliamcmillan.uk"
        method="post"
        enctype="text/plain"
        class="rounded-[1.75rem] border border-cream-200 bg-background p-8 shadow-soft sm:p-10"
        aria-label="Contact Dalia"
      >
        <div class="flex items-center gap-3">
          <span class="grid h-10 w-10 place-items-center rounded-full bg-sage-100 text-primary" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16v16H4z"/>
              <path d="m4 6 8 7 8-7"/>
            </svg>
          </span>
          <div>
            <p class="text-xs uppercase tracking-[0.2em] text-terracotta-500">Send a message</p>
            <p class="mt-1 font-display text-xl leading-snug">I usually reply within a day or two.</p>
          </div>
        </div>

        <div class="mt-8 space-y-5">
          <div>
            <label for="name" class="block text-sm font-medium text-foreground">Name</label>
            <input
              type="text"
              id="name"
              name="Name"
              autocomplete="name"
              required
              class="mt-2 block w-full rounded-lg border border-input bg-background px-4 py-3 text-[15px] text-foreground placeholder:text-muted-foreground focus:border-ring focus:outline-none focus:ring-2 focus:ring-ring/40"
              placeholder="Your name"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-foreground">Email</label>
            <input
              type="email"
              id="email"
              name="Email"
              autocomplete="email"
              required
              class="mt-2 block w-full rounded-lg border border-input bg-background px-4 py-3 text-[15px] text-foreground placeholder:text-muted-foreground focus:border-ring focus:outline-none focus:ring-2 focus:ring-ring/40"
              placeholder="you@example.com"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-foreground">Message</label>
            <textarea
              id="message"
              name="Message"
              rows="5"
              required
              class="mt-2 block w-full resize-y rounded-lg border border-input bg-background px-4 py-3 text-[15px] text-foreground placeholder:text-muted-foreground focus:border-ring focus:outline-none focus:ring-2 focus:ring-ring/40"
              placeholder="Tell me a little about what you'd like to work on."
            ></textarea>
          </div>
        </div>

        <div class="mt-8 flex flex-col-reverse items-start gap-4 sm:flex-row sm:items-center sm:justify-between">
          <p class="text-xs text-muted-foreground">
            Your message will open in your email app.<br />
            Prefer to book directly? <a href="https://calendly.com/daliamcdalia" target="_blank" rel="noopener" class="text-primary underline underline-offset-4">Use Calendly</a>.
          </p>
          <button
            type="submit"
            class="inline-flex items-center gap-2 rounded-full bg-primary px-7 py-3 text-[15px] font-medium text-primary-foreground shadow-soft transition-all hover:-translate-y-0.5 hover:shadow-medium"
          >
            Send message
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </button>
        </div>
      </form>
    </div>
  </section>
</Layout>
